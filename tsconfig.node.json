{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/main",
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "electron-vite.config.ts"]
}
